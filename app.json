{
  "expo": {
    "name": "REVOPZ Production",
    "slug": "revopz-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "revopzmobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "com.anonymous.revopzmobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColour": "#FFF",
        "monochromeImage": "./assets/images/icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.revopzmobile",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFF",
          "image": "./assets/images/revopz-logo.png",
          "imageWidth": 200,
          "android": {
            "image": "./assets/images/revopz-logo.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-image",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Revopz to access your camera to scan barcodes and QR codes.",
          "microphonePermission": "Allow Revopz to access your microphone.",
          "barcodeScannerEnabled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a2d10f5c-9fd0-4386-86dc-757458ae1b0b"
      }
    }
  }
}